# --- Required ---

# PostgreSQL connection string used by the backend (Drizzle + node-postgres).
# Format: postgres://user:password@host:port/database
DATABASE_URL=postgres://user:password@localhost:5432/vedic_match

# --- Optional ---

# Port the Express server listens on. Defaults to 3000.
# PORT=3000

# Pino log level (trace|debug|info|warn|error|fatal). Defaults to info.
# LOG_LEVEL=info

# Set to "production" on the server. Turns on the HTTPS redirect + trust proxy,
# disables pretty-printed logs, and serves the built frontend from server/public.
NODE_ENV=development

# Comma-separated browser origins allowed to call the API. Leave unset when the
# API and frontend share an origin (the default single-process setup).
# CORS_ORIGIN=https://yourdomain.com

# Set to "true" to connect to Postgres over TLS (most managed providers need it).
# DATABASE_SSL=true
